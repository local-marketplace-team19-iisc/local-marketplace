# Frontend environment (Constitution P4: commit this example only; .env is gitignored)
# Base URL of the backend REST API (C-05).
VITE_API_BASE_URL=http://localhost:8000

# When "true", the service layer returns mock data (D3) instead of calling the backend.
# Set to "false" once the backend publishes the real endpoints.
VITE_USE_MOCKS=true

# Auth can be tested against the real backend while marketplace features stay mocked.
VITE_USE_AUTH_MOCKS=false
