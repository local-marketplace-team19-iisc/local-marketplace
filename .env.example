# Port the API server binds to (default 8000)
PORT=8081

# --------------------------------------------------------------------------- #
# Feature 002 — Conversational agent (Constitution P4: placeholders only)
# --------------------------------------------------------------------------- #
# Pick ONE planner backend. If both blocks are blank the agent falls back to
# the deterministic StubLLMClient (useful for offline grading).

# (a) Direct OpenAI — works outside the Cisco corporate network.
OPENAI_API_KEY=

# (b) Cisco Circuit (egai / Azure-OpenAI passthrough) — used on the Cisco
#     corporate network. Wire format documented in
#     backend/agent/planner.py::CircuitClient.
CIRCUIT_CLIENT_ID=
CIRCUIT_CLIENT_SECRET=
CIRCUIT_APP_KEY=
CIRCUIT_CHAT_URL=https://chat-ai.cisco.com
CIRCUIT_TOKEN_URL=https://id.cisco.com/oauth2/default/v1/token
CIRCUIT_MODEL=gpt-4o-mini
CIRCUIT_TIMEOUT=90

# Set to "false" when the corporate proxy intercepts TLS (matches the
# reference DDTSAutomation backend). Leave commented (or "true") otherwise.
# CIRCUIT_VERIFY_SSL=false

# Optional corporate HTTP proxy — picked up automatically when exported:
#   export HTTPS_PROXY=http://proxy.esl.cisco.com:8080
# PostgreSQL + PostGIS connection string (feature 003-vendor-customer-auth)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/local_marketplace

# --------------------------------------------------------------------------- #
# Feature 003 — Vendor & Customer Email/Password Authentication
# --------------------------------------------------------------------------- #
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=7
JWT_ALGORITHM=HS256

# Rate limiting
RATE_LIMIT_FAILED_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOCKOUT_MINUTES=15
RATE_LIMIT_SIGNUP_PER_IP_HOUR=10
