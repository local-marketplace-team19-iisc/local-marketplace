# Port the API server binds to (default 8000)
PORT=8081

# PostgreSQL connection
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=marketplace
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://marketplace:your_password_here@localhost:5432/marketplace
TEST_DATABASE_URL=postgresql+asyncpg://marketplace:your_password_here@localhost:5432/marketplace_test
