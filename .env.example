# Port the API server binds to
PORT=8000

# ---------------------------------------------------------------------------
# Feature 001 — DB Schema
# ---------------------------------------------------------------------------

# PostgreSQL connection (asyncpg is the canonical driver; session.py derives
# the sync psycopg URL automatically by replacing the scheme prefix)
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=marketplace
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://marketplace:your_password_here@localhost:5432/marketplace
TEST_DATABASE_URL=postgresql+asyncpg://marketplace:your_password_here@localhost:5432/marketplace_test

# ---------------------------------------------------------------------------
# Feature 002 — Conversational agent (Constitution P4: placeholders only)
# ---------------------------------------------------------------------------
# Pick ONE planner backend. If both blocks are blank the agent falls back to
# the deterministic StubLLMClient (useful for offline grading).

# (a) Direct OpenAI — works outside the corporate network.
OPENAI_API_KEY=

# (b) Cisco Circuit (egai / Azure-OpenAI passthrough) — used on the Cisco
#     corporate network. Wire format documented in
#     backend/agent/planner.py::CircuitClient.
CIRCUIT_CLIENT_ID=
CIRCUIT_CLIENT_SECRET=
CIRCUIT_APP_KEY=
CIRCUIT_CHAT_URL=https://chat-ai.cisco.com
CIRCUIT_TOKEN_URL=https://id.cisco.com/oauth2/default/v1/token
CIRCUIT_MODEL=gpt-4o-mini
CIRCUIT_TIMEOUT=90

# Set to "false" when the corporate proxy intercepts TLS.
# CIRCUIT_VERIFY_SSL=false

# ---------------------------------------------------------------------------
# Feature 003 — Vendor & Customer Email/Password Authentication
# ---------------------------------------------------------------------------
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=7
JWT_ALGORITHM=HS256

# Rate limiting
RATE_LIMIT_FAILED_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOCKOUT_MINUTES=15
RATE_LIMIT_SIGNUP_PER_IP_HOUR=10

# ---------------------------------------------------------------------------
# Feature 007 — Vercel + Supabase Deployment
# ---------------------------------------------------------------------------

# Supabase project identifiers (non-secret — visible in dashboard URL)
SUPABASE_PROJECT_REF=your_project_ref_here
SUPABASE_URL=https://your_project_ref_here.supabase.co

# Supabase API keys — copy from Supabase dashboard → Settings → API
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Runtime DB connection — Supabase Transaction pooler (port 6543)
# Used by the FastAPI app on every request (NullPool, serverless-safe)
DATABASE_URL=postgresql+asyncpg://postgres.your_project_ref_here:your_db_password_here@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct DB connection — Supabase port 5432 (no pooler)
# Used by Alembic migrations ONLY — never by the running API
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres:your_db_password_here@db.your_project_ref_here.supabase.co:5432/postgres

# Supabase MCP endpoint (HTTP/SSE transport) — registered via:
#   claude mcp add --scope project --transport http supabase "$SUPABASE_MCP_URL"
SUPABASE_MCP_URL=https://mcp.supabase.com/mcp?project_ref=your_project_ref_here

# CORS — comma-separated origins allowed by the FastAPI backend
# Local dev: http://localhost:3000   Production: https://<project>.vercel.app
CORS_ORIGINS=http://localhost:3000
